{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 6,

  "modules-left": [
    "custom/nixos",
    "hyprland/workspaces",
    "custom/media"
  ],

  "modules-center": [
    "hyprland/window"
  ],

  "modules-right": [
    "idle_inhibitor",
    "pulseaudio",
    "backlight",
    "battery",
    "network",
    "clock",
    "tray",
    "custom/power"
  ],

  "hyprland/workspaces": {
    "persistent-workspaces": { "*": 5 },
    "format": "{name}"
  },

  "clock": {
    "timezone": "Asia/Tashkent",
    "format": "{:%H:%M}",
    "format-alt": "{:%Y-%m-%d}"
  },

  "pulseaudio": {
    "format": "{volume}%  ",
    "format-muted": "󰝟 ",
    "on-click": "pavucontrol"
  },

  "backlight": {
    "format": "{percent}%  "
  },

  "battery": {
    "format": "{capacity}%  ",
    "format-charging": "{capacity}% ⚡",
    "states": {
      "warning": 30,
      "critical": 15
    }
  },

  "network": {
    "format-wifi": " ",
    "format-ethernet": "󰈀 ",
    "format-disconnected": "⚠",
    "on-click": "network-manager-applet"
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": " ",
      "deactivated": " "
    }
  },

  "custom/nixos": {
    "format": "",
    "on-click": "walker",
    "tooltip": false
  },

  "custom/power": {
    "format": "",
    "on-click": "wlogout",
    "tooltip": false
  }
}
